        // Display Toast Alerts
        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            const title = document.getElementById('toast-title');
            const msg = document.getElementById('toast-message');
            
            if (type === 'success') {
                toast.classList.replace('bg-rose-600', 'bg-emerald-600');
                title.innerText = 'BERHASIL';
            } else {
                toast.classList.replace('bg-emerald-600', 'bg-rose-600');
                title.innerText = 'INFORMASI';
            }
            
            msg.innerText = message;
            
            // Slide in animation
            toast.classList.remove('translate-y-[-100px]', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');
            
            // Slide out after 3.5 seconds
            setTimeout(() => {
                toast.classList.add('translate-y-[-100px]', 'opacity-0');
                toast.classList.remove('translate-y-0', 'opacity-100');
            }, 3500);
        }

        // Navigation Switching (Tab Control)
        function switchTab(tabId) {
            // Hide all tab sections
            document.querySelectorAll('.tab-content').forEach(el => {
                el.classList.add('hidden');
                el.classList.remove('block');
            });

            // Show selected tab
            const targetView = document.getElementById(`view-${tabId}`);
            if (targetView) {
                targetView.classList.remove('hidden');
                targetView.classList.add('block');
            }

            // Update Navigation Button States (Desktop)
            document.querySelectorAll('.nav-btn').forEach(btn => {
                if (btn.getAttribute('data-target') === tabId) {
                    btn.classList.add('bg-white/15', 'text-amber-400');
                    btn.classList.remove('text-white');
                } else {
                    btn.classList.remove('bg-white/15', 'text-amber-400');
                    btn.classList.add('text-white');
                }
            });

            // Update Navigation Button States (Mobile)
            document.querySelectorAll('.mobile-nav-btn').forEach(btn => {
                if (btn.getAttribute('data-target') === tabId) {
                    btn.classList.add('text-blue-600');
                    btn.classList.remove('text-slate-400');
                } else {
                    btn.classList.remove('text-blue-600');
                    btn.classList.add('text-slate-400');
                }
            });

            // Scroll back to top
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

