<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SMANDELA '98 - Portal Alumni SMAN 8 Cirebon Angkatan 1998</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome Icons for modern visuals -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts: Inter & Playfair Display for elegant touch -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,800;1,400&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }
        .font-serif-header {
            font-family: 'Playfair Display', serif;
        }
        /* Megamendung-inspired custom background styling */
        .megamendung-gradient {
            background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #0284c7 100%);
        }
        .megamendung-pattern {
            background-color: #0f172a;
            background-image: radial-gradient(circle at 100% 150%, #1e3a8a 24%, #0f172a 25%, #0f172a 28%, #1e3a8a 29%, #1e3a8a 36%, #0f172a 37%, #0f172a 40%, #0ea5e9 41%, #0ea5e9 48%, #0f172a 49%);
            background-size: 80px 40px;
        }
        /* Smooth transitions for tabs and interactive elements */
        .tab-transition {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        /* Custom card styling with subtle shadow and border */
        .glass-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(226, 232, 240, 0.8);
        }
    </style>
</head>
<body class="text-slate-800 min-h-screen flex flex-col pb-24 md:pb-0">

    <!-- Custom non-blocking Toast System instead of browser alerts -->
    <div id="toast" class="fixed top-5 left-1/2 -translate-x-1/2 md:translate-x-0 md:left-auto md:right-5 z-50 transform translate-y-[-100px] opacity-0 transition-all duration-300 bg-emerald-600 text-white px-6 py-3.5 rounded-xl shadow-2xl flex items-center gap-3">
        <span class="p-1 bg-white/20 rounded-lg"><i class="fa-solid fa-circle-check text-lg"></i></span>
        <div>
            <p id="toast-title" class="font-bold text-xs uppercase tracking-wider">Berhasil</p>
            <p id="toast-message" class="text-sm font-medium">Data berhasil diperbarui!</p>
        </div>
    </div>

    <!-- DESKTOP HEADER (Hidden on mobile) -->
    <header class="megamendung-gradient text-white shadow-md sticky top-0 z-40 hidden md:block">
        <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="flex items-center space-x-3 cursor-pointer" onclick="switchTab('beranda')">
                <div class="w-12 h-12 bg-amber-400 rounded-full flex items-center justify-center text-slate-900 font-extrabold shadow-lg border-2 border-white text-xl">
                    98
                </div>
                <div>
                    <h1 class="text-lg font-extrabold tracking-tight leading-none text-white">SMANDELA 98 CIREBON</h1>
                    <p class="text-[10px] text-sky-200 uppercase tracking-widest mt-1">Ikatan Alumni SMA Negeri 8 Angkatan 1998</p>
                </div>
            </div>
            
            <nav class="flex items-center space-x-1">
                <button onclick="switchTab('beranda')" class="nav-btn px-3 py-2 rounded-xl font-semibold text-xs lg:text-sm transition-all duration-200 flex items-center gap-1.5 hover:bg-white/10" data-target="beranda">
                    <i class="fa-solid fa-house"></i> Beranda
                </button>
                <button onclick="switchTab('kabar')" class="nav-btn px-3 py-2 rounded-xl font-semibold text-xs lg:text-sm transition-all duration-200 flex items-center gap-1.5 hover:bg-white/10" data-target="kabar">
                    <i class="fa-solid fa-comment-dots"></i> Kabar Alumni
                </button>
                <button onclick="switchTab('direktori')" class="nav-btn px-3 py-2 rounded-xl font-semibold text-xs lg:text-sm transition-all duration-200 flex items-center gap-1.5 hover:bg-white/10" data-target="direktori">
                    <i class="fa-solid fa-users"></i> Cari Teman
                </button>
                <button onclick="switchTab('loker')" class="nav-btn px-3 py-2 rounded-xl font-semibold text-xs lg:text-sm transition-all duration-200 flex items-center gap-1.5 hover:bg-white/10" data-target="loker">
                    <i class="fa-solid fa-store"></i> UMKM & Loker
                </button>
                <button onclick="switchTab('memori')" class="nav-btn px-3 py-2 rounded-xl font-semibold text-xs lg:text-sm transition-all duration-200 flex items-center gap-1.5 hover:bg-white/10" data-target="memori">
                    <i class="fa-solid fa-images"></i> Nostalgia
                </button>
            </nav>

            <button onclick="openModal('modal-daftar')" class="bg-amber-400 hover:bg-amber-300 text-slate-900 font-bold px-4 py-2 rounded-xl shadow-md hover:shadow-lg transition-all duration-200 text-xs lg:text-sm flex items-center gap-1.5">
                <i class="fa-solid fa-user-plus"></i> Update Data Diri
            </button>
        </div>
    </header>

    <!-- MOBILE HEADER (Hidden on desktop) -->
    <header class="megamendung-gradient text-white shadow-md sticky top-0 z-40 md:hidden px-4 py-3.5 flex justify-between items-center">
        <div class="flex items-center space-x-2.5">
            <div class="w-9 h-9 bg-amber-400 rounded-full flex items-center justify-center text-slate-900 font-bold border-2 border-white text-sm">
                98
            </div>
            <div>
                <h1 class="text-sm font-bold leading-none tracking-tight">SMANDELA 98</h1>
                <p class="text-[9px] text-sky-200 uppercase tracking-wider">Alumni SMAN 8 Cirebon</p>
            </div>
        </div>
        <button onclick="openModal('modal-daftar')" class="bg-amber-400 hover:bg-amber-300 text-slate-900 text-xs font-bold py-1.5 px-3 rounded-lg shadow-md transition-all">
            <i class="fa-solid fa-user-pen mr-1"></i> Update Data
        </button>
    </header>

    <!-- MAIN CONTENT AREA -->
    <main class="flex-grow max-w-6xl w-full mx-auto p-4 md:p-6 mb-8">
        
        <!-- ================= VIEW 1: BERANDA ================= -->
        <section id="view-beranda" class="tab-content block space-y-6">
            <!-- Hero banner with nostalgia focus -->
            <div class="relative rounded-2xl overflow-hidden shadow-xl text-white megamendung-gradient">
                <div class="absolute inset-0 opacity-10 megamendung-pattern"></div>
                <div class="relative z-10 p-6 md:p-12 max-w-3xl space-y-4">
                    <span class="inline-block bg-amber-400 text-slate-950 text-xs px-3 py-1 rounded-full font-extrabold tracking-wider uppercase shadow-sm">
                        28 Tahun Perjalanan Sejak Kelulusan
                    </span>
                    <h2 class="text-3xl md:text-5xl font-extrabold font-serif-header tracking-tight leading-tight">
                        Temu Kangen & <br class="hidden md:block">Kolaborasi SMANDELA 98
                    </h2>
                    <p class="text-sm md:text-base text-slate-200 leading-relaxed font-light">
                        Selamat datang kembali di rumah digital alumni SMA Negeri 8 Cirebon Angkatan 1998. Di sini kita berkumpul, berbagi cerita, menyambung kembali tali persaudaraan, dan saling mendukung dalam karir maupun usaha keluarga besar alumni.
                    </p>
                    <div class="flex flex-wrap gap-3 pt-3">
                        <button onclick="switchTab('kabar')" class="bg-amber-400 text-slate-950 hover:bg-amber-300 font-bold px-5 py-2.5 rounded-xl shadow-lg transition-all text-sm flex items-center gap-2">
                            <i class="fa-solid fa-comments"></i> Lihat Kabar Terbaru
                        </button>
                        <button onclick="switchTab('direktori')" class="bg-white text-blue-900 hover:bg-slate-100 font-bold px-5 py-2.5 rounded-xl shadow-lg transition-all text-sm flex items-center gap-2">
                            <i class="fa-solid fa-magnifying-glass text-blue-700"></i> Cari Teman Sekelas
                        </button>
                    </div>
                </div>
            </div>

            <!-- Nostalgia Quote Widget -->
            <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5 shadow-sm flex items-start gap-4">
                <div class="p-3 bg-amber-400/20 text-amber-700 rounded-xl text-xl shrink-0 hidden sm:block">
                    <i class="fa-solid fa-heart-pulse"></i>
                </div>
                <div>
                    <h4 class="font-bold text-amber-900 text-sm">Sudut Nostalgia Angkatan '98: "Nongkrong Dekat Kantin & Lagu Kaset Tape"</h4>
                    <p class="text-xs text-amber-800 leading-relaxed mt-1">
                        Ingat saat kita nongkrong di dekat kantin koperasi, janjian pakai surat karena HP belum umum, atau dengerin lagu-lagu Sheila on 7, Dewa 19, dan Gigi lewat kaset pita? Angkatan 1998 adalah saksi transisi milenium baru. Mari pertahankan hubungan hangat ini selamanya!
                    </p>
                </div>
            </div>

            <!-- Stats Dashboard Card -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm text-center flex flex-col justify-center">
                    <div class="w-10 h-10 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-2 text-lg">
                        <i class="fa-solid fa-users"></i>
                    </div>
                    <div class="text-2xl md:text-3xl font-black text-slate-900" id="stat-alumni-count">0</div>
                    <p class="text-xs text-slate-500 font-semibold uppercase tracking-wider mt-1">Alumni Terdaftar</p>
                </div>
                <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm text-center flex flex-col justify-center">
                    <div class="w-10 h-10 bg-amber-50 text-amber-600 rounded-full flex items-center justify-center mx-auto mb-2 text-lg">
                        <i class="fa-solid fa-comment-dots"></i>
                    </div>
                    <div class="text-2xl md:text-3xl font-black text-slate-900" id="stat-status-count">0</div>
                    <p class="text-xs text-slate-500 font-semibold uppercase tracking-wider mt-1">Kabar & Status</p>
                </div>
                <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm text-center flex flex-col justify-center">
                    <div class="w-10 h-10 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-2 text-lg">
                        <i class="fa-solid fa-briefcase"></i>
                    </div>
                    <div class="text-2xl md:text-3xl font-black text-slate-900" id="stat-jobs-count">0</div>
                    <p class="text-xs text-slate-500 font-semibold uppercase tracking-wider mt-1">Loker & Usaha</p>
                </div>
                <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm text-center flex flex-col justify-center">
                    <div class="w-10 h-10 bg-rose-50 text-rose-600 rounded-full flex items-center justify-center mx-auto mb-2 text-lg">
                        <i class="fa-solid fa-bullhorn"></i>
                    </div>
                    <div class="text-2xl md:text-3xl font-black text-slate-900">2</div>
                    <p class="text-xs text-slate-500 font-semibold uppercase tracking-wider mt-1">Agenda Reuni</p>
                </div>
            </div>

            <!-- Grid: Event list & Bursa Kerja preview -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Agenda preview (Left) -->
                <div class="lg:col-span-2 bg-white rounded-2xl p-6 border border-slate-100 shadow-sm space-y-4">
                    <div class="flex justify-between items-center border-b pb-3">
                        <h3 class="font-bold text-slate-900 text-base flex items-center gap-2">
                            <i class="fa-solid fa-calendar-days text-blue-600"></i> Agenda & Kegiatan Reuni '98
                        </h3>
                        <button onclick="switchTab('memori')" class="text-xs font-bold text-blue-600 hover:underline">Lihat Semua</button>
                    </div>
                    
                    <div class="space-y-3.5">
                        <div class="flex items-center gap-4 p-3 bg-slate-50 rounded-xl hover:bg-slate-100/80 transition-all">
                            <div class="bg-blue-600 text-white rounded-lg p-2.5 text-center w-14 shrink-0 shadow-sm">
                                <p class="text-xs uppercase font-extrabold">Agst</p>
                                <p class="text-lg font-black leading-none">15</p>
                            </div>
                            <div class="flex-grow">
                                <span class="bg-blue-100 text-blue-800 text-[9px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">Silaturahmi</span>
                                <h4 class="font-bold text-slate-900 text-sm mt-1">Reuni Perak 28 Tahun & Halal Bihalal</h4>
                                <p class="text-xs text-slate-500 flex items-center gap-1.5 mt-0.5">
                                    <i class="fa-solid fa-location-dot text-slate-400"></i> Swiss-Belhotel Cirebon | 10:00 WIB
                                </p>
                            </div>
                        </div>

                        <div class="flex items-center gap-4 p-3 bg-slate-50 rounded-xl hover:bg-slate-100/80 transition-all">
                            <div class="bg-emerald-600 text-white rounded-lg p-2.5 text-center w-14 shrink-0 shadow-sm">
                                <p class="text-xs uppercase font-extrabold">Sep</p>
                                <p class="text-lg font-black leading-none">05</p>
                            </div>
                            <div class="flex-grow">
                                <span class="bg-emerald-100 text-emerald-800 text-[9px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">Sosial</span>
                                <h4 class="font-bold text-slate-900 text-sm mt-1">Bakti Sosial Peduli Sesama Alumni & Guru</h4>
                                <p class="text-xs text-slate-500 flex items-center gap-1.5 mt-0.5">
                                    <i class="fa-solid fa-location-dot text-slate-400"></i> Aula SMA Negeri 8 Cirebon
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Info Kontak Panitia (Right) -->
                <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm space-y-4 flex flex-col justify-between">
                    <div>
                        <h3 class="font-bold text-slate-900 text-base border-b pb-3 flex items-center gap-2">
                            <i class="fa-solid fa-headset text-amber-500"></i> Kontak Pengurus SMANDELA '98
                        </h3>
                        <p class="text-xs text-slate-500 mt-2.5 leading-relaxed">
                            Butuh bantuan registrasi, koreksi data, atau ingin menyalurkan bantuan sosial alumni angkatan 98? Hubungi Admin kami:
                        </p>
                        <div class="mt-4 space-y-2.5">
                            <a href="https://wa.me/628123456789" target="_blank" class="flex items-center gap-3 p-2.5 bg-emerald-50 rounded-xl hover:bg-emerald-100 transition-all group">
                                <span class="p-2 bg-emerald-500 text-white rounded-lg shadow-sm"><i class="fa-brands fa-whatsapp"></i></span>
                                <div class="text-left">
                                    <p class="text-xs text-emerald-800 font-bold leading-none">WhatsApp Admin 1</p>
                                    <p class="text-[11px] text-emerald-600 mt-0.5">Kang Budi (IPA 1)</p>
                                </div>
                            </a>
                            <a href="https://wa.me/628987654321" target="_blank" class="flex items-center gap-3 p-2.5 bg-emerald-50 rounded-xl hover:bg-emerald-100 transition-all group">
                                <span class="p-2 bg-emerald-500 text-white rounded-lg shadow-sm"><i class="fa-brands fa-whatsapp"></i></span>
                                <div class="text-left">
                                    <p class="text-xs text-emerald-800 font-bold leading-none">WhatsApp Admin 2</p>
                                    <p class="text-[11px] text-emerald-600 mt-0.5">Teh Dian (IPS 2)</p>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ================= VIEW 2: KABAR ALUMNI & KOMENTAR (NEW) ================= -->
        <section id="view-kabar" class="tab-content hidden space-y-6">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Left Column: Status Input and Status List -->
                <div class="lg:col-span-2 space-y-6">
                    <!-- Status Form Box -->
                    <div class="bg-white rounded-2xl p-5 border border-slate-100 shadow-sm space-y-4">
                        <div class="flex items-center gap-2 border-b pb-3">
                            <div class="p-2 bg-blue-50 text-blue-600 rounded-lg"><i class="fa-solid fa-pen-to-square text-lg"></i></div>
                            <div>
                                <h3 class="font-bold text-slate-900 text-base">Bagikan Kabar & Cerita Anda</h3>
                                <p class="text-xs text-slate-500">Tulis cerita, sapaan hangat, atau info menarik ke sesama alumni SMANDELA 98.</p>
                            </div>
                        </div>

                        <form id="form-buat-status" onsubmit="handlePostStatus(event)" class="space-y-3">
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                <div>
                                    <label class="block text-[10px] font-bold text-slate-600 uppercase mb-1">Nama Anda *</label>
                                    <input type="text" id="status-author" required class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-3 py-2 text-xs focus:ring-2 focus:ring-blue-500 focus:outline-none" placeholder="Contoh: Asep Sunandar">
                                </div>
                                <div>
                                    <label class="block text-[10px] font-bold text-slate-600 uppercase mb-1">Kelas *</label>
                                    <select id="status-class" required class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-3 py-2 text-xs focus:ring-2 focus:ring-blue-500 focus:outline-none">
                                        <option value="IPA 1">IPA 1</option>
                                        <option value="IPA 2">IPA 2</option>
                                        <option value="IPS 1">IPS 1</option>
                                        <option value="IPS 2">IPS 2</option>
                                    </select>
                                </div>
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold text-slate-600 uppercase mb-1">Pesan Status *</label>
                                <textarea id="status-content" required rows="3" class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl p-3 text-xs focus:ring-2 focus:ring-blue-500 focus:outline-none" placeholder="Tulis kabar Anda hari ini di sini..."></textarea>
                            </div>
                            <div class="flex justify-between items-center pt-2">
                                <p class="text-[10px] text-slate-400"><i class="fa-solid fa-circle-info"></i> Status akan langsung tampil di linimasa</p>
                                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs py-2 px-5 rounded-xl shadow-sm transition-all flex items-center gap-1.5">
                                    <i class="fa-solid fa-paper-plane"></i> Posting Kabar
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Status Feed Feed List -->
                    <div id="status-feed-container" class="space-y-4">
                        <!-- Dynamically filled with statuses -->
                    </div>
                </div>

                <!-- Right Column: Sidebar info and rules -->
                <div class="space-y-4">
                    <div class="bg-white rounded-2xl p-5 border border-slate-100 shadow-sm space-y-3">
                        <h4 class="font-bold text-slate-900 text-sm flex items-center gap-2"><i class="fa-solid fa-gavel text-amber-500"></i> Aturan Linimasa</h4>
                        <p class="text-xs text-slate-500 leading-relaxed">
                            Media ini dibuat untuk merayakan nostalgia, menjalin silaturahmi, dan memperkuat relasi bisnis SMANDELA 98. 
                        </p>
                        <ul class="text-[11px] text-slate-600 space-y-1.5 list-disc pl-4 font-light">
                            <li>Gunakan bahasa yang sopan dan hangat.</li>
                            <li>Dilarang membahas politik praktis, SARA, atau konten berbau ujaran kebencian.</li>
                            <li>Utamakan saling mendukung (guyub) dan menyemangati sesama alumni.</li>
                        </ul>
                    </div>

                    <div class="bg-indigo-50 border border-indigo-100 rounded-2xl p-5 shadow-sm">
                        <h4 class="font-bold text-indigo-900 text-sm flex items-center gap-1.5"><i class="fa-solid fa-rocket"></i> Saling Berdaya</h4>
                        <p class="text-xs text-indigo-800 leading-relaxed mt-1">
                            Punya lowongan kerja di tempat kantor Anda bekerja atau rintisan UMKM baru? Yuk bagikan di menu <strong>UMKM & Loker</strong> agar dibantu promosikan oleh rekan seangkatan.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ================= VIEW 3: DIREKTORI ALUMNI ================= -->
        <section id="view-direktori" class="tab-content hidden space-y-6">
            <div class="bg-white rounded-2xl p-5 md:p-6 border border-slate-100 shadow-sm space-y-4">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div>
                        <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
                            <i class="fa-solid fa-id-card-clip text-blue-600"></i> Direktori Resmi SMANDELA Angkatan 98
                        </h2>
                        <p class="text-xs text-slate-500 mt-1">Cari rekan seangkatan Anda berdasarkan nama, kelas, pekerjaan, atau domisili mereka saat ini.</p>
                    </div>
                    <button onclick="openModal('modal-daftar')" class="bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs py-2 px-4 rounded-xl shadow-sm transition-all flex items-center justify-center gap-1.5 shrink-0">
                        <i class="fa-solid fa-user-plus"></i> Gabung / Perbarui Profil Anda
                    </button>
                </div>

                <!-- Live Search and Filter Row -->
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 pt-2">
                    <div class="relative sm:col-span-1">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 pointer-events-none text-slate-400">
                            <i class="fa-solid fa-magnifying-glass text-sm"></i>
                        </span>
                        <input type="text" id="alumni-search-input" onkeyup="filterAlumni()" class="w-full bg-slate-50 border border-slate-200 text-slate-800 placeholder-slate-400 rounded-xl py-2.5 pl-10 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white" placeholder="Cari Nama / Pekerjaan...">
                    </div>

                    <div class="relative">
                        <select id="alumni-filter-class" onchange="filterAlumni()" class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl py-2.5 px-3.5 text-sm appearance-none focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white">
                            <option value="">Semua Kelas</option>
                            <option value="IPA 1">IPA 1</option>
                            <option value="IPA 2">IPA 2</option>
                            <option value="IPS 1">IPS 1</option>
                            <option value="IPS 2">IPS 2</option>
                        </select>
                        <span class="absolute inset-y-0 right-0 flex items-center pr-3.5 pointer-events-none text-slate-400">
                            <i class="fa-solid fa-chevron-down text-xs"></i>
                        </span>
                    </div>

                    <div class="relative">
                        <select id="alumni-filter-city" onchange="filterAlumni()" class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl py-2.5 px-3.5 text-sm appearance-none focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white">
                            <option value="">Semua Kota Domisili</option>
                        </select>
                        <span class="absolute inset-y-0 right-0 flex items-center pr-3.5 pointer-events-none text-slate-400">
                            <i class="fa-solid fa-chevron-down text-xs"></i>
                        </span>
