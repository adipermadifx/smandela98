                        <!-- Comment form box inside card -->
                        <form onsubmit="handlePostComment(event, '${status.id}')" class="flex gap-2 pt-2 border-t border-slate-100">
                            <input type="text" placeholder="Tulis komentar..." required class="flex-grow bg-white border border-slate-200 text-slate-800 rounded-lg px-3 py-1.5 text-xs focus:ring-2 focus:ring-blue-500 focus:outline-none">
                            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs px-3.5 py-1.5 rounded-lg shadow-sm shrink-0 flex items-center justify-center">
                                <i class="fa-solid fa-paper-plane"></i>
                            </button>
                        </form>
                    </div>
                `;

                feedContainer.appendChild(statusCard);
            });
        }

        // Handler to post a new status update
        function handlePostStatus(e) {
            e.preventDefault();

            const author = document.getElementById('status-author').value.trim();
            const userClass = document.getElementById('status-class').value;
            const content = document.getElementById('status-content').value.trim();

            const newStatus = {
                id: `status-${Date.now()}`,
                author: author,
                class: userClass,
                avatar: `https://placehold.co/150/1e3a8a/ffffff?text=${encodeURIComponent(author.charAt(0))}`,
                content: content,
                timestamp: "Baru saja",
                likes: 0,
                comments: []
            };

            statusState.unshift(newStatus);
            saveState();
            renderStatus();

            document.getElementById('status-content').value = '';
            showToast('Kabar status berhasil diposting!');
        }

        // Handler for likes
        function handleLikeStatus(statusId) {
            const statusIndex = statusState.findIndex(s => s.id === statusId);
            if (statusIndex !== -1) {
                statusState[statusIndex].likes = (statusState[statusIndex].likes || 0) + 1;
                saveState();
                renderStatus();
            }
        }

        // Handler to post a dynamic comment
        function handlePostComment(e, statusId) {
            e.preventDefault();

            const commentInput = e.target.querySelector('input');
            const content = commentInput.value.trim();
            if (!content) return;

            const statusIndex = statusState.findIndex(s => s.id === statusId);
            if (statusIndex !== -1) {
                // Prompt-free identity logic: Since comments are casual, we find registered name or use 'Anonim Alumni'
                const authorName = "Alumni SMANDELA";
                
                const newComment = {
                    author: authorName,
                    class: "98",
                    content: content,
                    timestamp: "Baru saja"
                };

                if (!statusState[statusIndex].comments) {
                    statusState[statusIndex].comments = [];
                }

                statusState[statusIndex].comments.push(newComment);
                saveState();
                renderStatus();

                commentInput.value = '';
                showToast('Komentar Anda terkirim!');
            }
        }

        // Stats updater counter
        function updateStats() {
            document.getElementById('stat-alumni-count').innerText = alumniState.length;
            document.getElementById('stat-jobs-count').innerText = lokerState.length;
            document.getElementById('stat-status-count').innerText = statusState.length;
        }

        // Countdown Reuni Perak System
        function initCountdown() {
            // Target date: Reuni Perak 15 Agustus 2026
            const targetDate = new Date("Aug 15, 2026 10:00:00").getTime();

            function updateTimer() {
                const now = new Date().getTime();
                const difference = targetDate - now;

                if (difference < 0) {
                    clearInterval(countdownInterval);
                    document.getElementById('countdown-days').innerText = "0";
                    document.getElementById('countdown-hours').innerText = "0";
                    document.getElementById('countdown-minutes').innerText = "0";
                    document.getElementById('countdown-seconds').innerText = "0";
                    return;
                }

                // Calculating intervals
                const days = Math.floor(difference / (1000 * 60 * 60 * 24));
                const hours = Math.floor((difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((difference % (1000 * 60)) / 1000);

                // Update UI elements securely
                document.getElementById('countdown-days').innerText = days;
                document.getElementById('countdown-hours').innerText = hours;
                document.getElementById('countdown-minutes').innerText = minutes;
                document.getElementById('countdown-seconds').innerText = seconds;
            }

            updateTimer(); // Initial call
            const countdownInterval = setInterval(updateTimer, 1000);
        }
    </script>
</body>
</html>
