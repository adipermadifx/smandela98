        // Filter and Search Algorithm
        function filterAlumni() {
            const searchKeyword = document.getElementById('alumni-search-input').value.toLowerCase();
            const classFilter = document.getElementById('alumni-filter-class').value;
            const cityFilter = document.getElementById('alumni-filter-city').value;

            const filtered = alumniState.filter(item => {
                const matchSearch = item.name.toLowerCase().includes(searchKeyword) || item.job.toLowerCase().includes(searchKeyword);
                const matchClass = classFilter === '' || item.class === classFilter;
                const matchCity = cityFilter === '' || item.city === cityFilter;

                return matchSearch && matchClass && matchCity;
            });

            renderAlumni(filtered);
        }

